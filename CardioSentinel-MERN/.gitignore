# .gitignore - CardioSentinel-MERN

# Dependencies
node_modules/
__pycache__/
*.pyc
venv/
env/
.venv/

# Environment variables
.env
.env.local
.env.*.local

# Frontend build
frontend/build/
frontend/dist/
frontend/.next/

# Backend
backend/logs/
backend/tmp/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# OS
.DS_Store
.windows/
ehthumbs.db

# Package managers
package-lock.json
yarn.lock
poetry.lock

# Testing
coverage/
.nyc_output/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Optional npm cache
.npm
.eslintcache

# Temporary files
tmp/
temp/
*.tmp
*.bak

# Model files (except metadata)
ai-service/model/*.pkl
ai-service/model/*.joblib
!ai-service/model/feature_columns.json

# Database backups
*.sql
*.dump

# Miscellaneous
.cache/
.eslintignore
.prettierignore
