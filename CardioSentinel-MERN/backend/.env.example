# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/cardiosentinel

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGIN=https://cardiosentinel-ten.vercel.app,http://localhost:3000

# AI Service Configuration
AI_SERVICE_URL=https://cardiosentinel-ai.onrender.com

# External APIs (optional)
SENDGRID_API_KEY=your_sendgrid_key_if_needed
